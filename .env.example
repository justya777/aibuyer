NEXTAUTH_SECRET=replace-with-strong-random-secret
NEXTAUTH_URL=http://localhost:3000

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/meta_saas

# Token encryption key for MetaCredential storage (required).
# Generate with: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=

# Legacy env-based tokens (deprecated — use DB-backed tokens via Admin UI).
# Kept as optional fallback; remove once all tenants migrated.
GLOBAL_SYSTEM_USER_TOKEN=
TENANT_SU_TOKEN_MAP=

GRAPH_API_VERSION=v23.0
GRAPH_MAX_RETRIES=3
GRAPH_BASE_DELAY_MS=300
GRAPH_MAX_DELAY_MS=3000
GRAPH_RETRY_JITTER_MS=100

POLICY_ENFORCEMENT_MODE=allow_with_warning
POLICY_MAX_BUDGET_INCREASE_PERCENT=50
POLICY_MAX_MUTATIONS_PER_TENANT_PER_HOUR=120
POLICY_BROAD_TARGETING_AGE_SPAN_THRESHOLD=35

# Optional app env
OPENAI_API_KEY=
NGROK_URL=http://localhost:3000
LOG_LEVEL=info
PORT=3001
